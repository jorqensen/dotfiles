{{ if .install_just }}
# Just — Just a command runner | https://github.com/casey/just
if ! command -v just &> /dev/null; then
    curl --proto '=https' --tlsv1.2 -sSf https://just.systems/install.sh | bash -s -- --to "$LOCAL_BIN"
fi
{{ end }}
{{ if .install_bun }}
# Bun — JavaScript runtime & toolkit | https://bun.sh
if ! command -v bun &> /dev/null; then
    curl -fsSL https://bun.sh/install | bash
    bun completions
fi
{{ end }}

{{ if .install_deno }}
# Deno — JavaScript/TypeScript runtime | https://deno.com
if ! command -v deno &> /dev/null; then
    curl -fsSL https://deno.land/install.sh | sh
    deno completions fish > $HOME/.config/fish/completions/deno.fish
fi
{{ end }}

{{ if .install_lazygit }}
# Lazygit — A Git TUI | https://github.com/jesseduffield/lazygit
if ! command -v lazygit &> /dev/null; then
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[0-9.]+')
    curl -LO "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
    tar xf "lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz" -C "$LOCAL_BIN" lazygit
    rm "lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
fi
{{ end }}

{{ if .install_lazydocker }}
